# OmniSyntax environment template

# API host/port
API_HOST=0.0.0.0
API_PORT=8000

# API runtime mode (used by start_api.py)
PRODUCTION=false

# API boundary hardening
# API_AUTH_MODE: disabled | api_key
API_AUTH_MODE=disabled
# Comma-separated API keys when API_AUTH_MODE=api_key
API_KEYS=
# Header carrying API key in protected mode
API_KEY_HEADER=X-API-Key
# Explicit unsafe override for public deployments with auth disabled
ALLOW_UNSAFE_PUBLIC_API=false

# Docs exposure (defaults to false in production if omitted)
ENABLE_API_DOCS=true

# Request safeguards
MAX_CODE_SIZE=100000
RATE_LIMIT_PER_MINUTE=100
# Rate limit backend: memory | redis
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_KEY_HEADER=X-API-Key

# CORS origins (comma-separated)
# Example:
# CORS_ORIGINS=http://localhost:3000,http://localhost:8501
CORS_ORIGINS=http://localhost:3000,http://localhost:8501,http://localhost:8000
